// -- aliasv2.cue --
@experiment(aliasv2)

package nhull

// ================================================================================
// Postfix field alias
// ================================================================================

f~right_hand_side: {n: 0}
r: right_hand_side.n

// ================================================================================
// Postfix single rhs alias
// ================================================================================

fo~X: {n: 1, lhs: null, rhs: X.n}

// ================================================================================
// Postfix tuple alias
// ================================================================================

foo~(K,V): {n: 2, l: K, r: V.n}

// ================================================================================
// Postfix tuple alias : dont care left hand side
// ================================================================================
//
fooo~(_,W): {n: 3, l: null, r: W.n}
//
//
// ================================================================================
// Postfix tuple alias : dont care right hand side
// ================================================================================
//
foooo~(L,_): {n: 4, l: L, v: null}
//
// ================================================================================
// Postfix pattern tuple alias : dont care left hand side
// ================================================================================
//
fooooo: {[string]~(_,Y): {n: 5, l: null, r: Y.n}} & {"": _}
//
// ================================================================================
// Postfix pattern tuple alias : dont care right hand side
// ================================================================================
//
foooooo: {[string]~(M,_): {n: 5, l: M, r: null}} & {a: _}
//
// ================================================================================
// Self reference
// ================================================================================
//
fooooooo: {
	n: 42
	l: self.n
	r: self.n
}
